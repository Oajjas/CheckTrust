# ─── CheckTrust — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in values before starting the server.

# Set to true only on a machine with a CUDA-compatible GPU
USE_GPU=false

# Set to true for verbose logging during development
DEBUG=false

# Maximum upload file size in megabytes (default: 10)
MAX_UPLOAD_SIZE_MB=10
